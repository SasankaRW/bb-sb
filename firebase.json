{
  "hosting": {
    "public": "src",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/scoreboardState.json",
        "destination": "/scoreboardState.json.html"
      }
    ],
    "headers": [
      {
        "source": "/scoreboardState.json",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          },
          {
            "key": "Cache-Control",
            "value": "no-store"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
