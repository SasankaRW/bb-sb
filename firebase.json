{
  "hosting": {
    "public": "src",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/scoreboardState.json",
        "destination": "https://bb-scoreboardnew-default-rtdb.asia-southeast1.firebasedatabase.app/matches/match1/liveScoreboard.json",
        "type": 302
      },
      {
        "source": "/scoreboardState-match2.json",
        "destination": "https://bb-scoreboardnew-default-rtdb.asia-southeast1.firebasedatabase.app/matches/match2/liveScoreboard.json",
        "type": 302
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
